<Window x:Class="sledzeniewydatkow.MainWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:vm="clr-namespace:sledzeniewydatkow"
       Title="Expense Tracker" Height="500" Width="800">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Nazwa wydatku" Grid.Row="0" Grid.Column="0" Margin="5"/>
            <TextBlock Text="Kwota (zł)" Grid.Row="0" Grid.Column="1" Margin="5"/>
            <TextBlock Text="Kategoria" Grid.Row="0" Grid.Column="2" Margin="5"/>
            <TextBlock Text="Data" Grid.Row="0" Grid.Column="3" Margin="5"/>

            <TextBox Grid.Row="1" Grid.Column="0" Margin="5" Text="{Binding Name}" />
            <TextBox Grid.Row="1" Grid.Column="1" Margin="5" Text="{Binding Amount}" />
            <TextBox Grid.Row="1" Grid.Column="2" Margin="5" Text="{Binding Category}" />
            <DatePicker Grid.Row="1" Grid.Column="3" Margin="5" SelectedDate="{Binding Date}" />

            <Button Grid.Row="1" Grid.Column="4" Content="Dodaj" Command="{Binding AddCommand}" Margin="5"/>
            <Button Grid.Row="1" Grid.Column="5" Content="Usuń ostatni" Command="{Binding DeleteCommand}" Margin="5"/>
        </Grid>

        <DataGrid Grid.Row="1"
                 ItemsSource="{Binding Expenses}"
                 AutoGenerateColumns="True"
                 Margin="0,10,0,10"/>
        
        <TextBlock Grid.Row="2"
                  FontSize="16"
                  FontWeight="Bold"
                  Text="{Binding Total, StringFormat='Suma: {0} zł'}"/>
    </Grid>
</Window>
